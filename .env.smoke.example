# Template for .env.smoke — copy to .env.smoke and fill in. The real file
# is gitignored (.env* pattern). scripts/smoke.mjs auto-loads .env.smoke
# when present, so you can just run `npm run smoke` without setting
# environment variables every time.
#
# Recommendation: create dedicated smoke accounts instead of using real
# admin/personal accounts. The smoke ADMIN credential gets read access to
# all patient records during the test — use a low-privilege STAFF role
# rather than ADMIN where possible. The smoke CLIENT credential drives the
# /portal flow tests.
#
# Caveat: the smoke also runs `POST /api/signup happy path` which creates
# a real signup row each run against SMOKE_URL. If pointed at prod, you'll
# accumulate fake-user rows over time. Safer: point SMOKE_URL at local dev
# (after `npm run dev`) for the signup-touching tests, and only run the
# subset against prod when you specifically want a prod check.

SMOKE_URL=https://www.manlyremedialthai.com.au

SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

SMOKE_CLIENT_EMAIL=
SMOKE_CLIENT_PASSWORD=

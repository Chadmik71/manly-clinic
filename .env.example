# --- Database ---
# Dev (SQLite): no setup required
DATABASE_URL="file:./dev.db"
# Prod (Postgres in Sydney region for Australian Privacy Act data residency):
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/clinic?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string-32+chars"
AUTH_URL="http://localhost:3000"

# --- Email (optional, for booking confirmations) ---
# RESEND_API_KEY=""
# EMAIL_FROM="bookings@yourclinic.com.au"

# --- SMS (optional, for booking reminders) ---
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM="+61400000000"

# --- Cron (optional) ---
# Used by /api/cron/reminders to authenticate scheduled requests.
# CRON_SECRET=""

# --- Stripe (optional, for online deposits and voucher purchases) ---
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("CLIENT") // CLIENT | STAFF | ADMIN
  emailVerified DateTime?
  // Imported clients: counts taken at import time, plus an external id from
  // the source system so re-imports don't duplicate.
  externalId    String?   @unique
  visitCount    Int       @default(0)
  noShowCount   Int       @default(0)
  notes         String?
  // Patient demographics (clinical record)
  dob           DateTime?
  gender        String?   // MALE | FEMALE | OTHER | PREFER_NOT_TO_SAY
  addressLine1  String?
  suburb        String?
  stateRegion   String?   // NSW | VIC | QLD | SA | WA | TAS | ACT | NT | other
  postcode      String?
  // GP / referring doctor
  gpName        String?
  gpClinic      String?
  gpPhone       String?
  // Health-fund details persisted at the user level so they pre-fill
  // across bookings even when the most recent IntakeForm wasn't a claim
  // visit (which would null these out on the per-booking snapshot).
  // Updated whenever a customer submits with claimWithHealthFund=true.
  healthFundName         String?
  healthFundMemberNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings        Booking[]        @relation("ClientBookings")
  notesAuthored   Booking[]        @relation("ClinicalNoteAuthor")
  assignedBookings    Booking[]    @relation("AssignedTherapist")
  assignedByBookings  Booking[]    @relation("AssignedBy")
  intakeForms     IntakeForm[]
  consentRecords  ConsentRecord[]
  auditLogs       AuditLog[]
  therapist       Therapist?
}

// --- Clinic ---

model Service {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  category    String // RELAXATION | THERAPEUTIC | SPECIALTY | ADD_ON
  description String?
  active      Boolean    @default(true)
  healthFundEligible Boolean @default(false)
  // Manual sort position for customer-facing lists (lower = first). Set via
  // the up/down reorder controls on the staff Services page. Ties broken by
  // name. Additive/non-destructive column.
  displayOrder Int       @default(0)
  createdAt   DateTime   @default(now())
  variants    ServiceVariant[]
  bookings    Booking[]
}

model ServiceVariant {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  durationMin Int
  priceCents  Int
  bookings    Booking[]

  @@unique([serviceId, durationMin])
}

model Therapist {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  // What customers see when picking a therapist (e.g. "Therapist 1").
  // Falls back to user.name if null. Lets the clinic operate with rotating
  // staff while keeping the customer-facing booking flow stable.
  displayName   String?
  qualifications String? // free text, e.g. "Cert IV Massage Therapy, AAMT member"
  // Required on tax invoices for health-fund rebates
  providerNumber String?
  associationName String? // AAMT | MTAA | ATMS | MMA | other
  active        Boolean  @default(true)
  availability  Availability[]
  bookings      Booking[]
  timeOff       TimeOff[]
}

model Availability {
  id          String     @id @default(cuid())
  therapistId String
  therapist   Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek   Int        // 0 = Sunday ... 6 = Saturday
  startMin    Int        // minutes from midnight
  endMin      Int

  @@index([therapistId, dayOfWeek])
}

model TimeOff {
  id          String     @id @default(cuid())
  therapistId String
  therapist   Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
}

// --- Booking ---

model Booking {
  id              String    @id @default(cuid())
  reference       String    @unique // human-friendly e.g. MNL-A4F2K
  clientId        String
  client          User      @relation("ClientBookings", fields: [clientId], references: [id])
  serviceId       String
  service         Service   @relation(fields: [serviceId], references: [id])
  variantId       String
  variant         ServiceVariant @relation(fields: [variantId], references: [id])
  therapistId     String?
  therapist       Therapist? @relation(fields: [therapistId], references: [id])
  startsAt        DateTime
  endsAt          DateTime
  status          String    @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
  priceCentsAtBooking Int
  claimWithHealthFund Boolean @default(false)
  notes           String?
  isWalkIn        Boolean   @default(false)
  cancelledAt     DateTime?
  cancelReason    String?
  cancellationFeeCents Int  @default(0)
  paidCents       Int       @default(0)
  paymentIntentId String?
  voucherCode     String?
  voucherAppliedCents Int   @default(0)

  // Per-visit clinical notes (SOAP + extras). Captured by the treating
  // therapist after the session. All optional — older bookings, walk-ins,
  // or sessions that skip notes will leave these null.
  noteSubjective    String?
  noteObjective     String?
  noteAssessment    String?
  notePlan          String?
  noteAreasTreated  String?
  noteTechniques    String?
  noteOutcome       String?
  noteAuthorId      String?
  noteAuthor        User?     @relation("ClinicalNoteAuthor", fields: [noteAuthorId], references: [id])
  noteUpdatedAt     DateTime?
  /// PNG data URL of the staff-drawn annotation overlay on the body diagram
  /// (e.g. circles around trigger points, free-form notes). Captured per
  /// booking by the treating therapist; null when no annotation was drawn.
  noteAnnotationsPng String?

  // Service-slot model (e.g. "Therapist 1"). Customers always see this label
  // in their portal/confirmations. The actual therapist (when relevant for
  // remedial bookings) is stored separately in therapistId. Both nullable so
  // legacy bookings continue to work.
  slotId          String?
  slot            Slot?     @relation(fields: [slotId], references: [id])
  slotLabel       String?   // denormalized snapshot at booking time, stable even if slot is renamed/deleted

  // Therapist assigned by admin AFTER the booking is made (separate from
  // the customer-facing slot label). For health-fund-rebate audits — these
  // fields are the official "who actually did the session" record. The name
  // is denormalised (frozen at assignment time) so renaming the User later
  // never rewrites historical bookings.
  assignedTherapistId   String?
  assignedTherapist     User?     @relation("AssignedTherapist", fields: [assignedTherapistId], references: [id])
  assignedTherapistName String?
  assignedAt            DateTime?
  assignedById          String?
  assignedBy            User?     @relation("AssignedBy", fields: [assignedById], references: [id])

  // Couple booking link — nullable. Two bookings sharing a coupleGroupId
  // are partner halves of the same couple-massage appointment. Each half
  // still has its own service/variant/therapist; the field just lets us link
  // them for cancellation prompts and audit views.
  coupleGroupId   String?

  refundRequests  RefundRequest[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([startsAt])
  @@index([clientId])
  @@index([therapistId])
  @@index([slotId, startsAt])
  @@index([coupleGroupId])
}

/// Client-submitted request to refund a paid deposit, requiring admin
/// approval before money moves. One booking can have many rows over its
/// lifetime (a DECLINED request can be re-submitted later) but only one
/// open at a time — enforced via check-then-insert in requestRefund,
/// since Prisma can't express partial unique indexes.
///
/// Status machine:
///   REQUESTED ──► APPROVED ──► PROCESSED   (stripe.refunds.create returned)
///       │            └────────► FAILED      (stripe call threw — terminal,
///       │                                    admin must refund manually
///       │                                    via Stripe dashboard)
///       └─────────► DECLINED
///
/// PROCESSED only means our Stripe API call returned a refund id. The
/// downstream Booking.paidCents decrement happens through the existing
/// charge.refunded webhook handler — same path used by every other refund
/// (manual dashboard, in-policy auto-refund, etc.).
model RefundRequest {
  id              String    @id @default(cuid())
  bookingId       String
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reason          String?
  status          String    @default("REQUESTED") // REQUESTED | APPROVED | DECLINED | PROCESSED | FAILED
  /// Snapshot of the refund amount in cents at request time. Today this
  /// is always the full deposit (no partial refunds), but stored so
  /// historical rows stay correct if the deposit amount changes later.
  amountCents     Int

  requestedAt     DateTime  @default(now())
  decidedAt       DateTime?
  /// User.id of the admin who approved or declined. Denormalised (no FK)
  /// to match the DailyCapacityOverride.createdBy pattern.
  decidedById     String?
  /// Admin name frozen at decision time so historical rows aren't rewritten
  /// when a User is later renamed.
  decidedByName   String?
  declineReason   String?

  /// Stripe refund id (re_...) — set when the API call succeeds.
  stripeRefundId  String?
  /// Last Stripe error message when status=FAILED. For admin diagnosis only.
  stripeError     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([bookingId])
  @@index([requestedAt])
}

// --- Health intake (Privacy Act compliant) ---

model IntakeForm {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Health information collected with explicit consent (APP 3)
  // Free-text fields kept for flexibility / extra detail.
  medicalConditions String?
  medications       String?
  allergies         String?
  injuries          String?
  // Structured medical-history checklist (JSON array of condition codes)
  medicalHistory    String?
  // Presenting complaint
  painLocation      String?  // e.g. "lower back, right side"
  painScale         Int?     // 0-10
  painOnset         String?  // when it started, brief
  painHistory       String?  // aggravating/relieving factors, prior treatment
  treatmentGoals    String?
  // Pregnancy
  pregnancy         Boolean? @default(false)
  pregnancyWeeks    Int?
  // Emergency contact
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  // Health-fund claim details (required when Booking.claimWithHealthFund = true)
  healthFundName        String?
  healthFundMemberNumber String?
  reasonForTreatment    String?
  // Consent tracking (APP 5 notification, APP 6 use)
  consentToTreat    Boolean  @default(false)
  consentToStore    Boolean  @default(false)
  signedAt          DateTime?
  /// PNG data URL of the client's drawn signature. Required for health-fund
  /// claims (HICAPS audit trail), null when there is no claim.
  signatureDataUrl  String?
  /// JSON-serialized array of body-diagram zone codes the client tapped on
  /// the intake form (e.g. ["f-shoulder-l", "b-lower-back"]). Pairs with the
  /// free-text painLocation field — the diagram is the structured view, the
  /// text field is the supplemental detail.
  painLocationCodes  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // PRIVACY_POLICY | MARKETING | HEALTH_INFO_STORAGE | TREATMENT
  version     String
  granted     Boolean
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// --- Audit (Privacy Act, Notifiable Data Breaches) ---

model Voucher {
  id              String   @id @default(cuid())
  code            String   @unique
  amountCents     Int
  balanceCents    Int
  purchaserId     String?
  recipientName   String
  recipientEmail  String
  message         String?
  status          String   @default("ACTIVE") // ACTIVE | REDEEMED | EXPIRED | CANCELLED
  expiresAt       DateTime?
  paidCents       Int      @default(0)
  paymentIntentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([recipientEmail])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // LOGIN | VIEW_HEALTH_INFO | CREATE_BOOKING | etc.
  resource    String?  // e.g. "Booking:abc123"
  ipAddress   String?
  userAgent   String?
  metadata    String?  // JSON string
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Service slot — customer-facing label like "Therapist 1", "Therapist 2".
/// Each clinic operates N concurrent slots at any time; admin can toggle
/// individual slots active/inactive when short-staffed.
model Slot {
  id           String    @id @default(cuid())
  label        String    @unique // e.g. "Therapist 1"
  displayOrder Int       @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@index([active, displayOrder])
}

model DailyCapacityOverride {
  id             String   @id @default(cuid())
  date           String   @unique // YYYY-MM-DD in Sydney TZ
  maxActiveSlots Int      // CAP: effective active slot count for this date is min(this, total active slots)
  reason         String?
  createdAt      DateTime @default(now())
  createdBy      String?  // User.id of admin who set it (denormalised, no FK)
}


// Singleton settings row for clinic-wide feature flags.
//
// Always has exactly one row with id = "default". The application creates it
// lazily on first read if missing (see lib/clinic-settings.ts) so we do not
// rely on a seed step that might be skipped in some environments.
//
// Fields are explicit columns (not key/value) so type safety follows through
// from Prisma into the staff settings UI.
model ClinicSetting {
  id                    String    @id @default("default") // singleton; only one row exists
  depositsEnabled       Boolean   @default(true)          // master kill switch for online deposits
  cardSurchargeEnabled  Boolean   @default(false)         // when true, add cardSurchargeBps to deposit
  cardSurchargeBps      Int       @default(150)           // surcharge in basis points (150 = 1.50%)
  updatedAt             DateTime  @updatedAt
  updatedBy             String?                            // User.id of admin who last changed it
}
